# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 13002)
PORT=13002

# Periodically refresh discovered free models into the local fallback chain.
# Set MODEL_REFRESH_ENABLED=false or interval <=0 to disable.
MODEL_REFRESH_ENABLED=true
MODEL_REFRESH_INTERVAL_MINUTES=360
MODEL_REFRESH_ON_STARTUP=true
